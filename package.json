    "js-yaml": "^4.1.1",
    "lodash": "4.18.1",
    "mime": "^4.1.0",
    "nanoid": "^5.1.7",
    "next": "16.2.6",
    "node-cache": "5.1.2",
    "node-gyp": "12.2.0",
    "node-schedule": "2.1.1",
    "nodemailer": "8.0.5",
    "openpgp": "6.3.0",
    "pg": "8.20.0",
    "pug": "3.0.4",
    "react": "19.2.6",
    "react-ace": "14.0.1",
    "react-animate-height": "3.2.3",
    "react-aria": "3.47.0",
    "react-dom": "19.2.6",
