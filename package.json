    "ua-parser-js": "^2.0.9",
    "undici": "^8.1.0",
    "validator": "^13.15.35",
    "web-push": "3.6.7",
    "wink-jaro-distance": "^2.0.0",
    "winston": "3.19.0",
    "winston-daily-rotate-file": "5.0.0",
    "xml2js": "0.6.2",
